# HTTP server
HTTP_ADDR=:8080

# Worker pool / ingestion
WORKERS=8
QUEUE_SIZE=1024
MAX_HISTORY=1000

# Real-time status reconciliation
OFFLINE_AFTER=30s
RECONCILE_EVERY=10s

# MongoDB (NoSQL). Leave MONGO_URI empty to use the in-memory store.
MONGO_URI=mongodb://localhost:27017
MONGO_DB=iot

# Redis (status cache + distributed event bus). Leave REDIS_ADDR empty to disable.
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_STATUS_TTL=5m

# MQTT broker. Leave MQTT_BROKER_URL empty to disable MQTT ingestion.
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_TOPIC_PREFIX=devices
MQTT_CLIENT_ID=
MQTT_USERNAME=
MQTT_PASSWORD=

# JWT authentication. Leave JWT_SECRET empty to disable auth (local dev only).
# When set, protected routes require a Bearer token from /api/auth/login.
JWT_SECRET=
JWT_TTL=15m
JWT_REFRESH_TTL=168h

# Bootstrap admin user, seeded at startup when it does not already exist.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
